# Large binary originals — tracked via CHECKSUMS.txt only
binaries/original/*.exe
binaries/original/*.dll
binaries/original/*.bin
!binaries/original/CHECKSUMS.txt
patches/experimental/*.exe
patches/experimental/*.dll
patches/experimental/*.bin

# Ghidra project files
*.gpr
*.rep/

# Python cache
__pycache__/
*.pyc
*.pyo
.venv/

# Nix
result
result-*

# Logs (optional — keep for reference)
# logs/

# OS
.DS_Store

# Run artifact: hook DT log (lands in project root under bwrap --chdir)
eaw-mt.log
